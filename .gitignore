# Dart / Flutter
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# Flutter ephemeral / generated (regenerated by `flutter create`/build)
app/android/.gradle/
app/android/local.properties
app/**/GeneratedPluginRegistrant.*
app/windows/flutter/ephemeral/
app/linux/flutter/ephemeral/
app/macos/Flutter/ephemeral/
app/ios/Flutter/ephemeral/
*.g.dart.lock

# Library packages do not commit lockfiles (apps may override locally).
pubspec.lock

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Local env / secrets — never commit key material
*.seed
*.key
secrets.*
